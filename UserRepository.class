<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
	<title>Payment</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

	<div class="container mt-5">
		<div class="card shadow p-4">
			<h4 class="fw-bold">Payment</h4>
			<p>User: <b th:text="${user.name}"></b></p>
			<p>Email: <b th:text="${user.email}"></b></p>

			<button class="btn btn-success w-100 fw-bold mt-3">
				Pay Now
			</button>
		</div>
	</div>

</body>
<script>
function goToPayment() {

    const loggedIn =
        document.getElementById("loggedInFlag").value === "true";

    const seatSelected =
        document.getElementById("seatSelectedFlag").value === "true";

    // ❌ Seat not selected
    if (!seatSelected) {
        alert("❗ Please select seat first");
        return;
    }

    // ❌ Not logged in → open login modal
    if (!loggedIn) {
        openLoginModal('payment');
        return;
    }

    // ✅ Seat selected + Logged in → PAYMENT PAGE
    window.location.href = "/payment";
}
</script>

</html>